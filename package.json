{
  "name": "notepet",
  "version": "1.0.0",
  "description": "Desktop pet sticky notes",
  "author": "NeKO",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.notepet.app",
    "productName": "NotePet",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "src/**",
      "assets/**",
      "data/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.0.0"
  }
}
